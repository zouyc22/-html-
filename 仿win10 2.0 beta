calc:{
title:"计算器",icon:"🔢",w:320,h:460,
html:`
<input id="calcInput" style="width:100%;height:50px;font-size:22px;text-align:right;" readonly>
<div style="display:grid;grid-template-columns:repeat(4,1fr);margin-top:8px;">
<button class="calc-num">7</button><button class="calc-num">8</button><button class="calc-num">9</button><button class="calc-num">/</button>
<button class="calc-num">4</button><button class="calc-num">5</button><button class="calc-num">6</button><button class="calc-num">*</button>
<button class="calc-num">1</button><button class="calc-num">2</button><button class="calc-num">3</button><button class="calc-num">-</button>
<button class="calc-num">0</button><button class="calc-num">.</button><button class="calc-num">C</button><button class="calc-num">+</button>
<button class="calc-num" style="grid-column:span 4;">=</button>
</div>
`,
init:function(win){
const inp = win.querySelector("#calcInput");
const btns = win.querySelectorAll(".calc-num");
let exp = "";
btns.forEach(b=>{
b.onclick = ()=>{
const val = b.innerText;
if(val === "C"){exp = "";inp.value = "";}
else if(val === "="){
try{inp.value = eval(exp);}catch{e=>inp.value="错误";exp="";}
}else{exp+=val;inp.value = exp;}
}
})
}
},
paint:{
title:"画图工具",icon:"🎨",w:760,h:520,
html:`
<div style="display:flex;gap:8px;margin-bottom:8px;">
<button id="pen">画笔</button>
<button id="eraser">橡皮</button>
<input type="color" id="colorPick" value="#000000">
<input type="range" id="lineWidth" min="1" max="30" value="5">
<button id="clearCanvas">清空画布</button>
</div>
<canvas id="paintCanvas" style="border:1px solid #ccc;width:100%;height:calc(100% - 70px);"></canvas>
`,
init:function(win){
const canvas = win.querySelector("#paintCanvas");
const ctx = canvas.getContext("2d");
canvas.width = canvas.offsetWidth;
canvas.height = canvas.offsetHeight;
let draw = false,mode="pen",color="#000",lineW=5;
function redraw(){
ctx.lineCap = "round";
ctx.lineJoin = "round";
}
win.querySelector("#pen").onclick = ()=>mode="pen";
win.querySelector("#eraser").onclick = ()=>mode="eraser";
win.querySelector("#colorPick").oninput = e=>color=e.target.value;
win.querySelector("#lineWidth").oninput = e=>lineW=+e.target.value;
win.querySelector("#clearCanvas").onclick = ()=>ctx.clearRect(0,0,canvas.width,canvas.height);
canvas.onmousedown = e=>{draw=true;redraw();ctx.beginPath();ctx.moveTo(e.offsetX,e.offsetY);}
canvas.onmousemove = e=>{
if(!draw)return;
ctx.lineWidth = lineW;
ctx.strokeStyle = mode=="eraser"?"#fff":color;
ctx.lineTo(e.offsetX,e.offsetY);ctx.stroke();
}
canvas.onmouseup = ()=>draw=false;
canvas.onmouseleave = ()=>draw=false;
}
},
