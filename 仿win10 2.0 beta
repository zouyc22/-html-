terminal:{
title:"终端",icon:"⌨️",w:700,h:460,
html:`
<div class="terminal" id="termBox">C:\\Users\\User> </div>
<input id="termInput" style="width:100%;margin-top:8px;" placeholder="输入命令，支持 ls / cls / help / date">
`,
init:function(win){
const box = win.querySelector("#termBox");
const inp = win.querySelector("#termInput");
inp.onkeydown = e=>{
if(e.key!=="Enter")return;
const cmd = inp.value.trim();
let out = "";
if(cmd==="cls"){box.innerText="C:\\Users\\User> ";inp.value="";return;}
if(cmd==="help")out = "可用命令：cls 清屏 | help 帮助 | date 时间 | ls 文件列表";
else if(cmd==="date")out = new Date().toString();
else if(cmd==="ls")out = "桌面 文档 下载 图片 音乐";
else if(cmd)out = `未知命令: ${cmd}`;
box.innerText += out + "\nC:\\Users\\User> ";
inp.value = "";
box.scrollTop = box.scrollHeight;
}
}
},
