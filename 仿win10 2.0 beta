<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>仿 Windows 10 完整版系统</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:"Segoe UI",system-ui,-apple-system,sans-serif;user-select:none;}
body{overflow:hidden;height:100vh;background:#0078d7;transition:background 0.3s;}
::-webkit-scrollbar{width:8px;height:8px;}
::-webkit-scrollbar-thumb{background:#aaa;border-radius:4px;}

/* 桌面 */
#desktop{width:100%;height:calc(100vh - 40px);padding:24px;display:grid;grid-template-columns:repeat(auto-fill,86px);gap:16px;}
.desktop-icon{width:86px;text-align:center;color:#fff;padding:6px;border-radius:4px;cursor:pointer;}
.desktop-icon:hover{background:rgba(255,255,255,0.18);}
.icon-img{font-size:42px;margin-bottom:6px;}

/* 任务栏 */
#taskbar{height:40px;width:100%;background:#191919;position:fixed;bottom:0;display:flex;align-items:center;z-index:9999;}
#start-btn{width:48px;height:100%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:22px;cursor:pointer;transition:background 0.15s;}
#start-btn:hover{background:#303030;}
.task-apps{display:flex;height:100%;gap:2px;}
.task-item{height:100%;min-width:46px;padding:0 12px;color:#fff;display:flex;align-items:center;cursor:pointer;border-bottom:2px solid #0078d7;background:rgba(255,255,255,0.04);transition:0.15s;}
.task-item.inactive{border-bottom:2px solid transparent;opacity:0.72;background:transparent;}
.task-item:hover{background:#3a3a3a;}
.task-right{margin-left:auto;color:#fff;padding:0 16px;font-size:13px;height:100%;display:flex;align-items:center;gap:14px;}

/* 开始菜单 */
#start-menu{width:390px;height:520px;background:#1f1f1f;position:fixed;bottom:40px;left:0;display:none;padding:12px;color:#fff;z-index:9998;box-shadow:0 0 24px #0006;overflow-y:auto;}
.start-title{font-size:16px;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid #444;}
.start-app-item{padding:9px 12px;cursor:pointer;border-radius:3px;margin:3px 0;display:flex;align-items:center;gap:10px;}
.start-app-item:hover{background:#333;}

/* 窗口通用 */
.window{position:absolute;width:820px;height:540px;background:#fff;box-shadow:0 6px 26px rgba(0,0,0,0.35);display:none;flex-direction:column;z-index:100;border:1px solid #ccc;overflow:hidden;transition:opacity 0.15s ease;}
.window-top{height:34px;background:#0078d7;display:flex;align-items:center;padding:0 10px;color:#fff;cursor:move;}
.window-title{flex:1;font-size:14px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.window-controls{display:flex;height:100%;}
.win-btn{width:48px;height:100%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;transition:background 0.12s;}
.win-btn:hover{background:rgba(255,255,255,0.18);}
.win-btn.close:hover{background:#e81123;}
.win-content{flex:1;overflow:auto;padding:10px;color:#222;background:#fff;}
.window.minimized{opacity:0;pointer-events:none;}

/* 右键菜单 */
.context-menu{position:fixed;width:190px;background:#fff;border:1px solid #d0d0d0;box-shadow:3px 3px 12px #0004;display:none;z-index:99999;}
.ctx-item{padding:9px 14px;cursor:pointer;font-size:14px;}
.ctx-item:hover{background:#0078d7;color:#fff;}

/* 通用组件样式 */
textarea,input[type="text"],input[type="number"]{border:1px solid #ccc;padding:6px;font-size:14px;outline:#0078d7 2px solid transparent;border-radius:3px;}
textarea:focus,input:focus{outline:#0078d7 2px solid;}
button{padding:6px 12px;background:#0078d7;color:#fff;border:none;border-radius:3px;cursor:pointer;}
button:hover{background:#0067c0;}
.setting-row{margin:14px 0;display:flex;align-items:center;gap:10px;}
.wallpaper-option{width:60px;height:40px;border:1px solid #888;cursor:pointer;}
.app-grid{display:grid;grid-template-columns:repeat(4,100px);gap:12px;margin-top:10px;}
.app-card{border:1px solid #ddd;padding:8px;text-align:center;border-radius:4px;cursor:pointer;}
.app-card:hover{background:#f0f7ff;}
.calc-num{width:60px;height:60px;font-size:20px;margin:3px;}
.music-item{padding:6px;border-bottom:1px solid #eee;cursor:pointer;}
.music-item:hover{background:#f2f2f2;}
.terminal{background:#000;color:#0f0;padding:10px;font-family:Consolas,monospace;height:100%;white-space:pre-wrap;}
#saveModal{position:fixed;width:320px;background:#fff;border:1px solid #999;box-shadow:0 0 20px #0005;padding:16px;z-index:10000;display:none;}
.modal-title{font-size:15px;margin-bottom:10px;font-weight:bold;}
</style>
</head>
<body>
<!-- 保存弹窗（记事本） -->
<div id="saveModal">
<div class="modal-title">保存文件</div>
<input type="text" id="saveFileName" placeholder="文件名.txt" style="width:100%;margin-bottom:10px;">
<div style="display:flex;gap:8px;justify-content:flex-end;">
<button id="confirmSave">保存</button>
<button id="cancelSave">取消</button>
</div>
</div>

<!-- 桌面 -->
<div id="desktop"></div>

<!-- 开始菜单 -->
<div id="start-menu">
<div class="start-title">所有应用</div>
<div id="startAppList"></div>
</div>

<!-- 任务栏 -->
<div id="taskbar">
<div id="start-btn">⊞</div>
<div class="task-apps" id="taskApps"></div>
<div class="task-right">
<span id="timeBox">00:00</span>
</div>
</div>

<!-- 窗口容器 -->
<div id="windowsBox"></div>

<!-- 任务栏右键菜单 -->
<div class="context-menu" id="taskCtx">
<div class="ctx-item" data-act="min">最小化窗口</div>
<div class="ctx-item" data-act="max">最大化</div>
<div class="ctx-item" data-act="close">关闭应用</div>
</div>

<script>
// 全局数据
const windows = {};
