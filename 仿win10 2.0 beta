</div>
`,
init:function(win){
const content = win.querySelector("#setContent");
const tabs = win.querySelectorAll(".setTab");
const wallList = ["#0078d7","#242424","#34495e","#27ae60","#8e44ad"];
function renderTab(tab){
if(tab=="wall"){
let html = "<h3>桌面壁纸</h3><div style='display:flex;gap:8px;margin:10px 0;'>";
wallList.forEach(c=>html+=`<div class="wallpaper-option" style="background:${c}" data-col="${c}"></div>`);
html+="</div><p>点击色块切换桌面背景</p>";
content.innerHTML = html;
win.querySelectorAll(".wallpaper-option").forEach(d=>{
d.onclick = ()=>{
document.body.style.background = d.dataset.col;
localStorage.setItem("sys_wall",d.dataset.col);
}
})
}else if(tab=="theme"){
content.innerHTML = `
<h3>窗口标题栏颜色</h3>
<div class="setting-row">
<label>自定义颜色：</label>
<input type="color" id="themeCol" value="#0078d7">
</div>
<button id="saveTheme">应用主题</button>
`;
win.querySelector("#saveTheme").onclick = ()=>{
const c = win.querySelector("#themeCol").value;
document.querySelectorAll(".window-top").forEach(t=>t.style.background = c);
localStorage.setItem("sys_theme",c);
}
}else if(tab=="window"){
content.innerHTML = `
<h3>窗口透明度</h3>
<div class="setting-row">
<input type="range" id="winOpacity" min="0.5" max="1" step="0.05" value="1">
<span id="opVal">100%</span>
</div>
<button id="applyOp">应用</button>
`;
const opSlider = win.querySelector("#winOpacity");
opSlider.oninput = ()=>win.querySelector("#opVal").innerText = Math.round(opSlider.value*100)+"%";
win.querySelector("#applyOp").onclick = ()=>{
const val = opSlider.value;
document.querySelectorAll(".window").forEach(w=>w.style.opacity = val);
localStorage.setItem("sys_op",val);
