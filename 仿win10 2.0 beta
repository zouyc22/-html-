`;
}
}
tabs.forEach(t=>t.onclick = ()=>renderTab(t.dataset.tab));
renderTab("wall");
// 读取本地配置
if(localStorage.getItem("sys_wall")) document.body.style.background = localStorage.getItem("sys_wall");
if(localStorage.getItem("sys_theme")){
document.querySelectorAll(".window-top").forEach(t=>t.style.background = localStorage.getItem("sys_theme"));
}
if(localStorage.getItem("sys_op")){
document.querySelectorAll(".window").forEach(w=>w.style.opacity = localStorage.getItem("sys_op"));
