calendar:{
title:"日历",icon:"📅",w:460,h:440,
html:`
<div style="text-align:center;">
<h3 id="calTitle"></h3>
<div style="display:grid;grid-template-columns:repeat(7,1fr);gap:6px;margin-top:12px;">
