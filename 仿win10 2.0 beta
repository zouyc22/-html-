settings:{
title:"系统设置",icon:"⚙️",w:740,h:500,
html:`
<div style="display:flex;height:100%;">
<div style="width:160px;border-right:1px solid #ddd;padding:8px;">
<p class="setTab" data-tab="wall">个性化壁纸</p>
<p class="setTab" data-tab="theme">主题颜色</p>
<p class="setTab" data-tab="window">窗口设置</p>
