// 初始化桌面图标、开始菜单
function initDesktop(){
const deskBox = document.getElementById("desktop");
const startList = document.getElementById("startAppList");
Object.keys(appConfig).forEach(id=>{
const app = appConfig[id];
// 桌面图标
const icon = document.createElement("div");
icon.className = "desktop-icon";
icon.dataset.app = id;
icon.innerHTML = `<div class="icon-img">${app.icon}</div><div>${app.title}</div>`;
deskBox.appendChild(icon);
// 开始菜单项
const startItem = document.createElement("div");
startItem.className = "start-app-item";
startItem.dataset.app = id;
startItem.innerHTML = `<span style="font-size:20px;">${app.icon}</span>${app.title}`;
startList.appendChild(startItem);
})
// 点击打开应用
document.querySelectorAll(".desktop-icon,.start-app-item").forEach(el=>{
el.onclick = e=>{e.stopPropagation();openApp(el.dataset.app);}
})
}

// 文件下载工具（记事本保存）
function downloadFile(name,text){
const blob = new Blob([text],{type:"text/plain"});
const a = document.createElement("a");
a.href = URL.createObjectURL(blob);
a.download = name;
a.click();
URL.revokeObjectURL(a.href);
}

// 保存弹窗逻辑
document.getElementById("confirmSave").onclick = ()=>{
const fn = document.getElementById("saveFileName").value.trim()||"笔记.txt";
downloadFile(fn,currentSaveApp);
document.getElementById("saveModal").style.display = "none";
}
document.getElementById("cancelSave").onclick = ()=>{
document.getElementById("saveModal").style.display = "none";
}
document.addEventListener("click",e=>{
if(!document.getElementById("saveModal").contains(e.target)){
document.getElementById("saveModal").style.display = "none";
}
})

// 更新任务栏时间
function updateTime(){
const d = new Date();
const h = String(d.getHours()).padStart(2,"0");
const m = String(d.getMinutes()).padStart(2,"0");
document.getElementById("timeBox").innerText = h+":"+m;
}
setInterval(updateTime,1000);
updateTime();

// 开始菜单开关
document.getElementById("start-btn").onclick = e=>{
e.stopPropagation();
const m = document.getElementById("start-menu");
m.style.display = m.style.display=="block"?"none":"block";
}
document.body.onclick = ()=>{
document.getElementById("start-menu").style.display = "none";
document.getElementById("taskCtx").style.display = "none";
}

// 打开应用
function openApp(appId){
const cfg = appConfig[appId];
if(windows[appId]){focusWindow(appId);return;}
zIndexNum++;
const win = document.createElement("div");
win.className = "window";
win.dataset.app = appId;
win.style.left = 60 + Object.keys(windows).length*32 + "px";
win.style.top = 60 + Object.keys(windows).length*32 + "px";
win.style.width = cfg.w + "px";
win.style.height = cfg.h + "px";
win.style.zIndex = zIndexNum;
win.style.display = "flex";
win.innerHTML = `
<div class="window-top">
<span class="window-title">${cfg.icon} ${cfg.title}</span>
<div class="window-controls">
<div class="win-btn min">─</div>
<div class="win-btn max">□</div>
<div class="win-btn close">×</div>
</div>
</div>
<div class="win-content">${cfg.html}</div>
`;
document.getElementById("windowsBox").appendChild(win);
windows[appId] = win;
createTaskItem(appId);
bindWindowEvent(win,appId);
// 执行应用初始化功能
if(cfg.init) cfg.init(win);
}

// 创建任务栏图标
function createTaskItem(appId){
const cfg = appConfig[appId];
const taskBox = document.getElementById("taskApps");
const t = document.createElement("div");
t.className = "task-item";
t.dataset.app = appId;
t.innerText = cfg.icon+" "+cfg.title;
t.onclick = e=>{
e.stopPropagation();
const w = windows[appId];
if(w.style.display==="none"){w.style.display="flex";focusWindow(appId);}
else if(getActiveApp()===appId){w.style.display="none";refreshTaskActive();}
else focusWindow(appId);
}
// 任务栏右键菜单
t.oncontextmenu = e=>{
e.preventDefault();
e.stopPropagation();
const ctx = document.getElementById("taskCtx");
ctx.style.left = e.clientX+"px";
ctx.style.top = e.clientY+"px";
ctx.style.display = "block";
ctx.dataset.targetApp = appId;
}
taskBox.appendChild(t);
refreshTaskActive();
}

// 任务栏右键操作
document.querySelectorAll("#taskCtx .ctx-item").forEach(item=>{
item.onclick = e=>{
const act = item.dataset.act;
const appId = document.getElementById("taskCtx").dataset.targetApp;
const win = windows[appId];
if(act==="min") win.style.display = "none";
if(act==="max") toggleMax(win);
if(act==="close") closeApp(appId);
document.getElementById("taskCtx").style.display = "none";
refreshTaskActive();
}
})

// 获取顶层窗口
function getActiveApp(){
let maxZ = 99,active = null;
Object.keys(windows).forEach(id=>{
const z = +windows[id].style.zIndex;
if(z>maxZ && windows[id].style.display!=="none"){maxZ=z;active=id;}
})
return active;
}

// 置顶窗口
function focusWindow(appId){
zIndexNum++;
const w = windows[appId];
w.style.zIndex = zIndexNum;
w.style.display = "flex";
refreshTaskActive();
}

// 更新任务栏激活状态
function refreshTaskActive(){
const active = getActiveApp();
document.querySelectorAll(".task-item").forEach(t=>{
if(t.dataset.app===active) t.classList.remove("inactive");
else t.classList.add("inactive");
})
}

// 关闭应用
function closeApp(appId){
windows[appId].remove();
delete windows[appId];
document.querySelectorAll(`.task-item[data-app="${appId}"]`).forEach(t=>t.remove());
refreshTaskActive();
}

let maxStore = {};
function toggleMax(win){
const aid = win.dataset.app;
if(!maxStore[aid]){
maxStore[aid] = {
l:win.style.left,t:win.style.top,w:win.style.width,h:win.style.height
};
win.style.left = "0";
win.style.top = "0";
win.style.width = "100%";
win.style.height = "calc(100vh - 40px)";
}else{
const s = maxStore[aid];
win.style.left = s.l;win.style.top = s.t;
win.style.width = s.w;win.style.height = s.h;
delete maxStore[aid];
}
}

// 窗口绑定拖拽、最小化、最大化、关闭
function bindWindowEvent(win,appId){
const topBar = win.querySelector(".window-top");
const minBtn = win.querySelector(".min");
const maxBtn = win.querySelector(".max");
const closeBtn = win.querySelector(".close");
win.onmousedown = ()=>focusWindow(appId);
// 流畅拖拽
topBar.onmousedown = e=>{
dragTarget = win;
dragOffsetX = e.clientX - win.offsetLeft;
dragOffsetY = e.clientY - win.offsetTop;
focusWindow(appId);
document.body.style.cursor = "move";
};
minBtn.onclick = e=>{e.stopPropagation();win.style.display = "none";refreshTaskActive();}
maxBtn.onclick = e=>{e.stopPropagation();toggleMax(win);}
closeBtn.onclick = e=>{e.stopPropagation();closeApp(appId);}
}

// 全局流畅拖拽
document.onmousemove = e=>{
if(!dragTarget) return;
requestAnimationFrame(()=>{
dragTarget.style.left = (e.clientX - dragOffsetX)+"px";
dragTarget.style.top = (e.clientY - dragOffsetY)+"px";
})
}
document.onmouseup = ()=>{dragTarget=null;document.body.style.cursor="default";}

// 页面加载初始化
window.onload = ()=>{
initDesktop();
}
</script>
</body>
</html>