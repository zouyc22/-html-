textarea.oninput = ()=>localStorage.setItem(key,textarea.value);
win.querySelector("#noteNew").onclick = ()=>textarea.value = "";
win.querySelector("#noteSave").onclick = ()=>{
if(!textarea.value) return alert("内容不能为空");
downloadFile("笔记.txt",textarea.value);
};
