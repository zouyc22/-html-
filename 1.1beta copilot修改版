// ===== 贪吃蛇（简单实现） =====
let snakeInt
function startSnake(){
  const canvas=document.getElementById('snakeCanvas'),ctx=canvas.getContext('2d')
  let snake=[{x:10,y:10}],dir={x:1,y:0},food={x:15,y:15}
  clearInterval(snakeInt)
  snakeInt=setInterval(()=>{
    ctx.fillStyle='#000';ctx.fillRect(0,0,canvas.width,canvas.height)
    const head={x:snake[0].x+dir.x,y:snake[0].y+dir.y};snake.unshift(head)
    if(head.x===food.x&&head.y===food.y)food={x:Math.random()*20|0,y:Math.random()*20|0}
    else snake.pop()
    ctx.fillStyle='#0f0';snake.forEach(p=>ctx.fillRect(p.x*16,p.y*16,14,14))
    ctx.fillStyle='#f00';ctx.fillRect(food.x*16,food.y*16,14,14)
  },150)
  canvas.onclick=e=>{
    const rect=canvas.getBoundingClientRect(),x=e.clientX-rect.left,y=e.clientY-rect.top
    const cx=rect.width/2,cy=rect.height/2
    if(Math.abs(x-cx)>Math.abs(y-cy))dir=x>cx?{x:1,y:0}:{x:-1,y:0}
    else dir=y>cy?{x:0,y:1}:{x:0,y:-1}
  }
}
function stopSnake(){clearInterval(snakeInt)}

